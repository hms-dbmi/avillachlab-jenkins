pipeline {
    agent any

    parameters {
        string(name: 'GIT_REPO_URL', defaultValue: '${git_base_url}/PIC-SURE-Logging.git', description: 'The GitHub repository URL')
        string(name: 'GIT_HASH', defaultValue: 'main', description: 'The Git hash to checkout')
        string(name: 'DOCKER_REPO', defaultValue: 'hms-dbmi', description: 'The Docker repository name')
        string(name: 'IMAGE_NAME', defaultValue: 'pic-sure-logging', description: 'The Docker image name')
        string(name: 'DOCKER_IMAGE_VERSION', defaultValue: 'latest', description: 'The Docker image version/tag')
        string(name: 'TARGET_STACK', description: 'a or b. The target stack.')
        string(name: 'STACK_S3_BUCKET', defaultValue: '${stack_s3_bucket}')
    }

    stages {
        stage('Clone Repository') {
            steps {
                script {
                    def ref = "${params.GIT_HASH}"
                    checkout([$class: 'GitSCM',
                        branches: [[name: ref]],
                        userRemoteConfigs: [[url: "${params.GIT_REPO_URL}"]]
                    ])
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh "docker build --no-cache -t '${params.DOCKER_REPO}/${params.IMAGE_NAME}:${params.DOCKER_IMAGE_VERSION}' ."
                }
            }
        }

        stage('Save Docker Image as TAR') {
            steps {
                script {
                    sh "docker save -o pic-sure-logging.tar.gz ${params.DOCKER_REPO}/${params.IMAGE_NAME}:${params.DOCKER_IMAGE_VERSION}"
                }
            }
        }

        stage('Upload TAR File to S3') {
            steps {
                script {
                    sh "aws s3 cp pic-sure-logging.tar.gz s3://${params.STACK_S3_BUCKET}/${params.TARGET_STACK}/containers/pic-sure-logging.tar.gz"
                }
            }
        }
    }
}
